# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-min-32-chars
SUPABASE_ANON_KEY=your-anon-key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/jiffylaundry
DATABASE_POOL_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# API Configuration
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_your_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key
STRIPE_WEBHOOK_SECRET=whsec_test_webhook_secret

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key

# Push Notifications
EXPO_ACCESS_TOKEN=your_expo_access_token
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Logging
LOG_LEVEL=info
SENTRY_DSN=

# External Services
GOOGLE_MAPS_API_KEY=
HERE_MAPS_API_KEY=

# Mobile App Configuration
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin Configuration
ADMIN_EMAIL=admin@jiffylaundry.com
ADMIN_PASSWORD=
ADMIN_2FA_SECRET=

# SLA Configuration
SLA_HOURS=24
REFUND_PERCENTAGE=100

# Queue Configuration
BULL_RETRY_ATTEMPTS=3
BULL_RETRY_DELAY=5000
