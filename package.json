{
  "name": "jiffylaundry-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install-all": "npm install",
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "clean": "find . -name node_modules -type d -prune -exec rm -rf {} \\;"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1"
  },
  "devDependencies": {
    "supabase": "^2.98.0",
    "typescript": "^5.3.3"
  }
}
