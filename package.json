{
  "name": "jiffylaundry",
  "version": "1.0.0",
  "description": "Production-grade laundry logistics platform",
  "private": true,
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:customer": "cd apps/customer-app && npm run dev",
    "dev:driver": "cd apps/driver-app && npm run dev",
    "dev:admin": "cd apps/admin-dashboard && npm run dev",
    "dev:staff": "cd apps/laundromat-dashboard && npm run dev",
    "build": "turbo build",
    "build:backend": "cd backend && npm run build",
    "build:admin": "cd apps/admin-dashboard && npm run build",
    "build:staff": "cd apps/laundromat-dashboard && npm run build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:backend": "cd backend && npm run test",
    "test:watch": "cd backend && npm run test:watch",
    "clean": "turbo clean && rm -rf node_modules pnpm-lock.yaml",
    "docker:up": "docker-compose -f infrastructure/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker-compose.yml down",
    "docker:logs": "docker-compose -f infrastructure/docker-compose.yml logs -f",
    "db:setup": "cd backend && npm run db:setup",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:seed": "cd backend && npm run db:seed",
    "deploy:backend": "cd backend && railway up",
    "deploy:admin": "cd apps/admin-dashboard && vercel --prod",
    "deploy:staff": "cd apps/laundromat-dashboard && vercel --prod",
    "deploy:all": "npm run deploy:backend && npm run deploy:admin && npm run deploy:staff"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "turbo": "^1.13.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "laundry",
    "logistics",
    "delivery",
    "sla",
    "realtime"
  ],
  "author": "Jiffy Laundry Team",
  "license": "PROPRIETARY"
}
