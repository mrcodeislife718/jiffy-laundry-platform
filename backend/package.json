{
  "name": "@jiffylaundry/backend",
  "version": "1.0.0",
  "description": "JiffyLaundry API Server",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm --no-warnings=ExperimentalWarning src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "db:setup": "node --loader ts-node/esm src/scripts/setupDatabase.ts",
    "db:migrate": "node --loader ts-node/esm src/scripts/migrate.ts",
    "db:seed": "node --loader ts-node/esm src/scripts/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.3.3",
    "socket.io": "^4.7.2",
    "redis": "^4.6.13",
    "bullmq": "^5.4.2",
    "@supabase/supabase-js": "^2.38.4",
    "stripe": "^14.14.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "dayjs": "^1.11.10",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "vitest": "^1.0.4",
    "@testing-library/react": "^14.1.2",
    "ts-node": "^10.9.2",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
